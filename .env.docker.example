APP_ENV=production
APP_PORT=3000
PM2_INSTANCES=1

JWT_SECRET=please-change-this-secret

MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=web_im_chat
MYSQL_USER=web_im
MYSQL_PASSWORD=web_im_password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci

REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=im
MESSAGE_RETENTION_SECONDS=86400
REDIS_APPENDONLY=yes
REDIS_MAXMEMORY_POLICY=noeviction

ENABLE_CALLS=false
NGINX_HTTP_PORT=80
NGINX_SERVER_NAME=_
NGINX_CLIENT_MAX_BODY_SIZE=100m
NGINX_UPLOAD_CACHE_EXPIRES=7d
NGINX_UPLOAD_CACHE_CONTROL=public, max-age=604800
NGINX_PROXY_READ_TIMEOUT=300
NGINX_PROXY_SEND_TIMEOUT=300
NGINX_SOCKET_TIMEOUT=86400
